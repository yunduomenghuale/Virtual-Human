DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# ===== 多模态大模型(统一处理文本 + 图片) =====
# qwen-vl-plus 支持文本对话、知识问答、图片隐患识别
TEXT_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
TEXT_LLM_API_KEY=sk-5de19211ad4f48ab8d47b122e203594f
TEXT_LLM_MODEL=qwen-vl-plus
# 快速模型(用于简单问题直答,不走 tool-calling 的场景)
FAST_LLM_MODEL=qwen-turbo

# ===== 视觉 LLM(与 TEXT_LLM 统一,保留独立配置以便后续拆分) =====
VISION_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_LLM_API_KEY=sk-5de19211ad4f48ab8d47b122e203594f
VISION_LLM_MODEL=qwen-vl-plus

VITE_XINGYUN_APP_ID=6e96053264e84c02906bb7e66a482801
VITE_XINGYUN_APP_SECRET=c20d6e07397f4b30a4ff35efcc759ead

# ===== Embedding(用于 RAG 向量化) =====
# 优先使用本地模型(BAAI/bge-small-zh-v1.5),加载失败时回退到远程 API
EMBEDDING_LOCAL_MODEL=BAAI/bge-small-zh-v1.5
# 远程 API 模型(阿里云 DashScope text-embedding-v3 / v2 / v1)
# 未配置 EMBEDDING_API_KEY 时会自动复用 TEXT_LLM_API_KEY
EMBEDDING_MODEL=text-embedding-v3
# 如需单独指定嵌入接口地址,取消下行注释
# EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 离线 / 无 API Key 场景使用 hash mock
USE_MOCK_EMBEDDING=False

# HuggingFace 镜像(本地模型下载用)
HF_ENDPOINT=https://hf-mirror.com

# ===== 高风险通知 =====
# 企业微信机器人 webhook 地址(可选,不配则不推送)
WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=b02f3346-7f6d-44db-a545-16eea8a54928
# 系统访问地址(用于消息中的链接)
BASE_URL=http://127.0.0.1:8000
