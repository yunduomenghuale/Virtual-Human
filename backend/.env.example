DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# ===== 文本 LLM(知识问答 / 报告生成 / agent 评价) =====
# 默认指向通义千问 OpenAI 兼容端点
TEXT_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
TEXT_LLM_API_KEY=sk-1f68284670124112a1232aa1dfce71f7
TEXT_LLM_MODEL=qwen-plus

# ===== 视觉 LLM(图片隐患识别) =====
VISION_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_LLM_API_KEY=sk-1f68284670124112a1232aa1dfce71f7
VISION_LLM_MODEL=qwen-vl-plus

# ===== Embedding(用于 RAG 向量化) =====
# 默认使用 sentence-transformers 本地模型(首次加载会下载)
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# 离线 / 无 API Key 场景使用 hash mock
USE_MOCK_EMBEDDING=False
# 国内访问 huggingface.co 不通时,改走镜像
HF_ENDPOINT=https://hf-mirror.com
