# ===================== Django 核心配置 =====================
# 生产环境必须修改为随机强密码，可用命令生成:
# python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-in-production

# 生产环境必须设为 False
DJANGO_DEBUG=False

# 允许的域名，多个用逗号分隔，不要写 *
DJANGO_ALLOWED_HOSTS=your-domain.com,127.0.0.1,localhost

# ===================== 大模型配置 (阿里云 DashScope) =====================
# 统一处理文本+图片的模型（qwen-vl-plus 支持多模态）
TEXT_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
TEXT_LLM_API_KEY=sk-your-api-key-here
TEXT_LLM_MODEL=qwen-vl-plus

# 快速模型（用于简单问题直答，不走 tool-calling）
FAST_LLM_MODEL=qwen-turbo

# 视觉模型（与 TEXT_LLM 统一，保留独立配置以便后续拆分）
VISION_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_LLM_API_KEY=sk-your-api-key-here
VISION_LLM_MODEL=qwen-vl-plus

# ===================== 数字人 SDK (魔珐星云) =====================
# 仅前端构建时需要，后端运行不需要
VITE_XINGYUN_APP_ID=your-app-id
VITE_XINGYUN_APP_SECRET=your-app-secret

# ===================== Embedding / RAG =====================
# 优先使用本地模型(BAAI/bge-small-zh-v1.5)，加载失败时回退到远程 API
EMBEDDING_LOCAL_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_MODEL=text-embedding-v3

# 如需单独指定嵌入接口地址，取消下行注释
# EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 未配置 EMBEDDING_API_KEY 时会自动复用 TEXT_LLM_API_KEY
EMBEDDING_API_KEY=

# 离线 / 无 API Key 场景使用 hash mock（会损失 RAG 精度，仅演示用）
USE_MOCK_EMBEDDING=False

# HuggingFace 镜像（国内服务器建议配置）
HF_ENDPOINT=https://hf-mirror.com

# ===================== 语音识别 (ASR) =====================
# 未配置 ASR_API_KEY 时自动复用 TEXT_LLM_API_KEY
ASR_API_KEY=
ASR_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/audio/asr/transcription
ASR_MODEL=paraformer-v1

# ===================== 系统配置 =====================
# 生产环境域名，用于生成报告/消息中的链接
BASE_URL=https://your-domain.com

# 企业微信机器人 webhook（可选，不配则不推送）
WECHAT_WEBHOOK_URL=
